{
  "name": "@caweb/theme",
  "description": "CA State Template WordPress, Divi Child Theme",
  "version": "1.14.0",
  "author": "Danny Guzman (https://github.com/Danny-Guzman/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Danny-Guzman/CAWeb/"
  },
  "license": "MIT",
  "devDependencies": {
    "@caweb/cli": "^1.14.10",
    "@caweb/icon-library": "^1.1.3",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1"
  },
  "scripts": {
    "caweb": "caweb",
    "build:all": "npm run build && npm run build:divi",
    "build:all:dev": "npm run build:dev && npm run build:divi:dev",
    "build": "caweb build --mode production && caweb build",
    "build:dev": "caweb build",
    "build:divi": "cd divi && npm run build",
    "build:divi:dev": "cd divi && npm run build:dev",
    "postinstall": "cd divi && npm install"
  }
}
